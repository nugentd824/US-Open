# ---------------------------------------------------------------------------
# Fairway Fantasy — environment configuration
# Copy this file to .env and fill in values. Never commit your real .env.
# ---------------------------------------------------------------------------

# HTTP/WebSocket server port
PORT=4000

# SQLite database file (relative to repo root or absolute)
DB_PATH=./data/app.db

# Allowed browser origins for cross-origin requests (split deploy: static client
# on Vercel, this backend on Render/Fly). Comma-separated, or "*" for any.
# e.g. CORS_ORIGINS=https://fairway-fantasy.vercel.app
CORS_ORIGINS=*

# --- Client build (Vite) ----------------------------------------------------
# Only needed for a SPLIT deploy. Set these in the Vercel project's env vars so
# the static client knows where the backend lives. Leave unset for local dev or
# single-server prod (the client then uses the same origin).
# VITE_API_BASE=https://fairway-fantasy.onrender.com
# VITE_WS_BASE is derived from VITE_API_BASE (http->ws) unless set explicitly.

# --- Odds provider (golfer field + win odds for the draft pool) -------------
# Options: mock | theoddsapi
ODDS_PROVIDER=mock
# Get a key at https://the-odds-api.com (free tier available).
ODDS_API_KEY=

# --- Score provider (live leaderboard / golfer scores) ----------------------
# Options: mock | sportradar
SCORE_PROVIDER=mock
# Sportradar Golf API key: https://developer.sportradar.com/ (Golf v3)
SPORTRADAR_API_KEY=
# Sportradar access level: trial | production
SPORTRADAR_ACCESS_LEVEL=trial

# How often the server polls the score provider and pushes updates (seconds).
# Real providers: 60-120 is polite. The mock simulates faster, so 15-30 is nice for demos.
SCORE_POLL_SECONDS=20

# --- Mock simulation pacing (only used when SCORE_PROVIDER=mock) -------------
# How many real seconds one simulated golf round takes. Lower = faster demo.
# Default 120s/round => a full 4-round "tournament" plays out in ~8 minutes.
MOCK_ROUND_SECONDS=120
