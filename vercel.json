{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci --workspace client --include-workspace-root=false",
  "buildCommand": "npm run build --workspace client -- --outDir ../dist --emptyOutDir",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
